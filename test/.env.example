# Smoke test + local prod-stack configuration.
# Copy to .env and fill in values before running.

# --- docker-compose vars ---

# Generate with: openssl rand -base64 32
JWT_SECRET=
ENCRYPTION_KEY=

# Optional overrides (defaults shown)
# DB_USER=ordovertex
# DB_PASSWORD=testpassword
# DB_NAME=ordovertex
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin1234!
# TZ=Europe/Stockholm

# Rate limiting — raise these for testing to avoid 429 errors during rapid test runs.
# In production NODE_ENV=production, the auth window defaults to 15 minutes.
# AUTH_RATE_LIMIT_MAX=1000
# AUTH_RATE_LIMIT_WINDOW_MS=60000

# --- smoke test vars ---

# API URL — use the docker-compose port (3011) for local testing,
# or your real prod URL for remote smoke runs.
API_URL=http://localhost:3011

# Credentials for the smoke test account.
# For docker-compose, use the ADMIN_EMAIL/ADMIN_PASSWORD values above.
TEST_EMAIL=admin@example.com
TEST_PASSWORD=Admin1234!
