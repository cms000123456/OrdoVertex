{
  "name": "ordovertex-backend",
  "version": "1.0.0",
  "description": "OrdoVertex - Open Source Workflow Automation Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "start:worker": "node dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:workspaces": "jest workspaces",
    "test:workflows": "jest workflows",
    "test:routes": "jest routes",
    "test:typecheck": "tsc --noEmit",
    "test:integration": "jest --config jest.integration.config.js",
    "test:pre-push": "npm run test:typecheck && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.7.0",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "anthropic": "^0.0.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "mssql": "^10.0.4",
    "mysql2": "^3.22.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "openai": "^4.104.0",
    "pg": "^8.20.0",
    "python-shell": "^5.0.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ssh2-sftp-client": "^12.1.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.40",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "tar": "^7.5.13",
    "fast-xml-parser": "^5.7.0",
    "@azure/identity": "^4.2.1",
    "@tootallnate/once": "^3.0.1"
  }
}
