# OrdoVertex Environment Configuration
# Copy this file to .env and update the values

# Required: Encryption key for credentials (min 32 characters)
ENCRYPTION_KEY=CHANGEME-32-character-random-key!

# Optional: Admin user credentials (defaults shown)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Optional: Rate limiting (development values)
AUTH_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
