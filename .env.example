# OrdoVertex Production Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Database Configuration
# ============================================
DB_USER=ordovertex
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DB_NAME=ordovertex

# ============================================
# REQUIRED: Redis Configuration
# ============================================
# Optional: Set a password for Redis
# REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ============================================
# REQUIRED: Security Secrets (GENERATE THESE!)
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ============================================
# Optional: Security Settings
# ============================================
# JWT token lifetime (default: 24h)
# JWT_EXPIRES_IN=24h

# CORS allowed origins (comma-separated)
# In production, set to your frontend domain:
# CORS_ORIGIN=https://app.yourdomain.com

# Allowed directories for file watch node
# ALLOWED_WATCH_DIRECTORIES=/data,/app/uploads

# ============================================
# Optional: Frontend API URL
# ============================================
# API_URL=https://api.yourdomain.com

# ============================================
# Docker Compose Specific
# ============================================
COMPOSE_PROJECT_NAME=ordovertex
