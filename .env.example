# OrdoVertex Environment Configuration
# Copy this file to .env and update the values

# ==========================================
# Required Secrets (generate with: openssl rand -base64 32)
# ==========================================

# JWT signing key (min 32 characters)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# Credential encryption key (min 32 characters, different from JWT_SECRET)
ENCRYPTION_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_32_CHAR_STRING

# ==========================================
# Database
# ==========================================

DATABASE_URL=postgresql://ordovertex:ordovertex_secret@localhost:5432/ordovertex

# ==========================================
# Redis
# ==========================================

REDIS_URL=redis://localhost:6379

# ==========================================
# Optional: Admin User (created on first startup if no admin exists)
# ==========================================

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ==========================================
# Optional: Rate Limiting
# ==========================================

# Auth endpoint rate limits (defaults are strict in production)
AUTH_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000

# ==========================================
# Optional: CORS
# ==========================================

# Comma-separated list of allowed origins
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# ==========================================
# Optional: Email (SMTP)
# ==========================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SECURE=false
# FROM_EMAIL=noreply@example.com
# FROM_NAME=OrdoVertex

# ==========================================
# Optional: General
# ==========================================

NODE_ENV=development
PORT=3001
LOG_LEVEL=info
